{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Capability for the main window",
  "windows": [
    "main",
    "add-host",
    "edit-host-*",
    "add-group",
    "edit-group-*",
    "settings",
    "credentials",
    "credentials-picker"
  ],
  "permissions": [
    "core:default",
    "opener:default",
    "core:event:default",
    "dialog:default",
    "allow-greet",
    "allow-add-host",
    "allow-get-host",
    "allow-update-host",
    "allow-get-hosts",
    "allow-delete-host",
    "allow-add-group",
    "allow-get-group",
    "allow-update-group",
    "allow-delete-group",
    "allow-get-groups",
    "allow-save-setting",
    "allow-get-setting",
    "allow-open-ssh-session",
    "allow-write-to-ssh",
    "allow-resize-ssh-session",
    "allow-close-ssh-session",
    "allow-open-pty-session",
    "allow-write-to-pty",
    "allow-resize-pty-session",
    "allow-close-pty-session",
    "core:window:allow-create",
    "core:window:allow-close",
    "core:window:allow-set-size",
    "core:window:allow-inner-size",
    "core:webview:allow-create-webview-window",
    "core:event:allow-emit",
    "core:event:allow-listen",
    "allow-get-snippets",
    "allow-add-snippet",
    "allow-delete-snippet",
    "allow-update-snippet",
    "allow-get-credentials",
    "allow-add-credential",
    "allow-delete-credential",
    "allow-update-credential",
    "allow-ask-ai",
    "allow-export-data",
    "allow-import-data",
    "fs:default",
    "fs:allow-read-text-file",
    "fs:allow-write-text-file",
    "allow-get-system-fonts",
    "allow-record-recent",
    "allow-get-recents",
    "allow-clear-recents",
    "allow-get-host-stats",
    "allow-get-completions",
    "allow-sftp-connect",
    "allow-sftp-read-dir",
    "allow-sftp-close",
    "allow-sftp-mkdir",
    "allow-sftp-delete",
    "allow-sftp-rename",
    "allow-sftp-download-file",
    "allow-sftp-upload-file"
  ]
}
