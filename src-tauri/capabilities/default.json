{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Capability for the main window",
  "windows": [
    "main",
    "add-host",
    "edit-host-*",
    "add-group",
    "edit-group-*"
  ],
  "permissions": [
    "core:default",
    "opener:default",
    "core:event:default",
    "allow-greet",
    "allow-add-host",
    "allow-get-host",
    "allow-update-host",
    "allow-get-hosts",
    "allow-delete-host",
    "allow-add-group",
    "allow-get-group",
    "allow-update-group",
    "allow-delete-group",
    "allow-get-groups",
    "allow-open-ssh-session",
    "allow-write-to-ssh",
    "allow-resize-ssh-session",
    "core:window:allow-create",
    "core:window:allow-close",
    "core:webview:allow-create-webview-window",
    "core:event:allow-emit",
    "core:event:allow-listen"
  ]
}
