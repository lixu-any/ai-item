{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Capability for the main window",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "opener:default",
    "core:event:default",
    "allow-greet",
    "allow-add-host",
    "allow-get-hosts",
    "allow-delete-host",
    "allow-add-group",
    "allow-get-groups",
    "allow-open-ssh-session",
    "allow-write-to-ssh"
  ]
}
